# /home/pi/edgeai/.env
# Edge AI Service Configuration
# Format: one KEY=value per line. No spaces around =. No quotes needed.
# Lines starting with # are comments — they are ignored.

MODEL_PATH=/home/pi/edgeai/models/model.tflite
CAMERA_ID=0
CONFIDENCE_THRESHOLD=0.75
MQTT_BROKER=192.168.1.100
MQTT_PORT=1883
MQTT_TOPIC=sensors/frames
API_KEY=your_secret_api_key_here
API_ENDPOINT=https://api.example.com/infer
LOG_LEVEL=INFO
