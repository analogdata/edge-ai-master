# Environment variables for the Edge AI inference service
# Analog Data — EdgeAI Engineering Bootcamp (Hands-on Lab)
#
# This file is loaded by:
#   - systemd:  via EnvironmentFile= in edgeai.service
#   - Docker:   not directly (Docker uses docker-compose.yml environment section)
#
# IMPORTANT: Protect this file — it may contain paths or secrets
#   chmod 600 /home/pi/edgeai/.env

# Path to the TFLite model file
MODEL_PATH=/home/pi/edgeai/models/model.tflite

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Seconds between inference frames (lower = faster but more CPU usage)
INFERENCE_INTERVAL=2.0
