# .env — Docker Compose automatically loads this file
# Analog Data — EdgeAI Engineering Bootcamp
#
# Place this file in the same directory as docker-compose.yml.
# Variables here are referenced in docker-compose.yml as ${VAR_NAME}.
#
# IMPORTANT: NEVER commit this file to git!
# Add ".env" to your .gitignore file.
# This file often contains secrets like API keys and passwords.

# API key for authentication (secret — don't share or commit!)
API_KEY=sk-1234567890abcdef

# Database connection string
DATABASE_URL=sqlite:///data/production.db

# You can add any variables you want here
# They are all available as ${VAR_NAME} in docker-compose.yml
